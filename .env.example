# Vyapar Ratna AI — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Market Data Sources ───────────────────────────────────────────────────────

# Zerodha Kite Connect (professional real-time NSE/BSE/MCX data)
# Sign up: https://kite.trade  (₹2000/month)
# Uncomment kiteconnect in requirements.txt to use
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=        # generated fresh each session via OAuth

# Angel One SmartAPI (free for Angel One account holders)
# https://smartapi.angelbroking.com/
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=        # for TOTP-based 2FA

# Alpha Vantage (global commodity + forex data)
# Free tier: 5 req/min, 500/day — https://www.alphavantage.co/
ALPHA_VANTAGE_KEY=

# Twelve Data (real-time global markets)
# https://twelvedata.com/
TWELVE_DATA_KEY=

# ── Backend Config ────────────────────────────────────────────────────────────

# Port (default 8000; Railway/Render override with $PORT)
PORT=8000

# Allowed CORS origins (comma-separated; * = allow all for local dev)
CORS_ORIGINS=*

# ── Optional: Sentry error tracking ──────────────────────────────────────────
SENTRY_DSN=
